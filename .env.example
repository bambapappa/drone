# Källa: tom = första filen i videos/. Kan vara filväg, rtsp://-URL eller kameraindex.
SOURCE=
VIDEO_DIR=videos
LOOP=true

# Modell: valfri Ultralytics .pt (COCO eller VisDrone-tränad). Klassnamn introspekteras.
MODEL=yolo11n.pt
DEVICE=cpu
IMGSZ=640
CONF=0.30

# Klassnamn som räknas som människa resp. hot (kommaseparerade, gemener)
HUMAN_CLASSES=person,pedestrian,people
THREAT_CLASSES=knife

# Utström
MAX_FPS=24
OUT_WIDTH=960
JPEG_QUALITY=70

DEBUG=false
