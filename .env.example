# Källa: tom = första filen i videos/. Kan vara filväg, rtsp://-URL eller kameraindex.
SOURCE=
VIDEO_DIR=videos
LOOP=true

# Modell: valfri Ultralytics .pt (COCO eller VisDrone-tränad). Klassnamn introspekteras.
# VisDrone (bättre på små människor från hög höjd):
#   python scripts/fetch_visdrone.py   # laddar ned till models/
#   MODEL=models/visdrone-yolov8s.pt   # samma sökväg funkar nativt och i Docker
MODEL=yolo11n.pt
DEVICE=cpu
IMGSZ=640
CONF=0.30

# Beskär analysen till en del av bilden ("x,y,w,h" normaliserat 0..1), t.ex.
# vänstra halvan av split-screen IR/visuell film: ANALYSIS_ROI=0,0,0.5,1
ANALYSIS_ROI=

# Klassnamn som räknas som människa (kommaseparerade, gemener)
HUMAN_CLASSES=person,pedestrian,people
# Hotflaggning är utlyft ur PoC 1 (rörledningen finns kvar) — sätt t.ex.
# THREAT_CLASSES=knife med en COCO-modell för att återaktivera.
THREAT_CLASSES=

# Utström
MAX_FPS=24
OUT_WIDTH=960
JPEG_QUALITY=70

DEBUG=false
